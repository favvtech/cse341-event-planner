{
  "swagger": "2.0",
  "info": {
    "title": "CSE341 Event Planner API",
    "description": "REST API for managing events and venues with MongoDB, validation, error handling, and GitHub OAuth.",
    "version": "1.0.0"
  },
  "host": "localhost:3000",
  "basePath": "/",
  "tags": [
